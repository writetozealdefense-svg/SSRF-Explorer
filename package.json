{
  "name": "ssrf-explorer",
  "version": "0.2.0",
  "description": "Desktop SSRF testing tool (MERN + Electron + PowerShell)",
  "main": "electron/main.js",
  "scripts": {
    "dev:client": "vite --config client/vite.config.js",
    "build:client": "vite build --config client/vite.config.js",
    "dev:server": "cross-env NODE_ENV=development node server/index.js",
    "dev": "concurrently -k -n ELECTRON,CLIENT \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV=1 electron .\" \"npm run dev:client\"",
    "start": "npm run build:client && electron .",
    "lint:check": "node -e \"require('./electron/main.js')\" || true"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.3.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  }
}
